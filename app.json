{
  "expo": {
    "name": "EdGo",
    "slug": "EdGo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "edgo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.EdGo"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-sqlite",
        {
          "enableFTS": true,
          "useSQLCipher": true,
          "android": {
            "enableFTS": false,
            "useSQLCipher": false
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/IntelOneMono_300Light.ttf",
            "./assets/fonts/IntelOneMono_400Regular.ttf",
            "./assets/fonts/IntelOneMono_500Medium.ttf",
            "./assets/fonts/IntelOneMono_600SemiBold.ttf",
            "./assets/fonts/IntelOneMono_700Bold.ttf",
            "./assets/fonts/IntelOneMono_300Light_Italic.ttf",
            "./assets/fonts/IntelOneMono_400Regular_Italic.ttf",
            "./assets/fonts/IntelOneMono_500Medium_Italic.ttf",
            "./assets/fonts/IntelOneMono_600SemiBold_Italic.ttf",
            "./assets/fonts/IntelOneMono_700Bold_Italic.ttf",
            "./assets/fonts/PTSerif_400Regular.ttf",
            "./assets/fonts/PTSerif_700Bold.ttf",
            "./assets/fonts/PTSerif_400Regular_Italic.ttf",
            "./assets/fonts/PTSerif_700Bold_Italic.ttf",
            "./assets/fonts/Rokkitt_100Thin.ttf",
            "./assets/fonts/Rokkitt_200ExtraLight.ttf",
            "./assets/fonts/Rokkitt_300Light.ttf",
            "./assets/fonts/Rokkitt_400Regular.ttf",
            "./assets/fonts/Rokkitt_500Medium.ttf",
            "./assets/fonts/Rokkitt_600SemiBold.ttf",
            "./assets/fonts/Rokkitt_700Bold.ttf",
            "./assets/fonts/Rokkitt_800ExtraBold.ttf",
            "./assets/fonts/Rokkitt_900Black.ttf",
            "./assets/fonts/Rokkitt_100Thin_Italic.ttf",
            "./assets/fonts/Rokkitt_200ExtraLight_Italic.ttf",
            "./assets/fonts/Rokkitt_300Light_Italic.ttf",
            "./assets/fonts/Rokkitt_400Regular_Italic.ttf",
            "./assets/fonts/Rokkitt_500Medium_Italic.ttf",
            "./assets/fonts/Rokkitt_600SemiBold_Italic.ttf",
            "./assets/fonts/Rokkitt_700Bold_Italic.ttf",
            "./assets/fonts/Rokkitt_800ExtraBold_Italic.ttf",
            "./assets/fonts/Rokkitt_900Black_Italic.ttf"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
